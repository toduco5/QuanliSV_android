<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F5F6FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ NGÀNH"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/edtMaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập mã ngành"
        android:minHeight="48dp"
        android:padding="12dp"
        android:inputType="text" />

    <EditText
        android:id="@+id/edtTenNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập tên ngành"
        android:layout_marginTop="10dp"
        android:minHeight="48dp"
        android:padding="12dp"
        android:inputType="textCapWords" />

    <Button
        android:id="@+id/btnThemNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THÊM NGÀNH"
        android:layout_marginTop="14dp"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/btnSuaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SỬA NGÀNH"
        android:layout_marginTop="8dp"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/btnXoaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XÓA NGÀNH"
        android:layout_marginTop="8dp"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/btnLamMoi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LÀM MỚI"
        android:layout_marginTop="8dp"
        android:minHeight="48dp" />

    <TextView
        android:id="@+id/tvDanhSachNganh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh sách ngành"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#1565C0"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="8dp" />

    <ListView
        android:id="@+id/lvNganh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#D9D9D9"
        android:dividerHeight="1dp" />

</LinearLayout>