<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".admin.DanhSachLopActivity">

    <EditText
        android:id="@+id/edtserchLop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:background="#FFFFFF"
        android:hint="Nhập tên lớp cần tìm"
        android:minHeight="48dp"
        android:padding="15dp"
        android:textColorHint="#3F51B5" />

    <ListView
        android:id="@+id/listviewLop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/edtserchLop"
        android:layout_marginBottom="57dp"
        tools:listitem="@layout/dong_xem_lop" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fbHomeLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginLeft="160dp"
                android:layout_marginBottom="30dp"
                android:contentDescription="Về trang chủ"
                android:src="@drawable/ic_home"
                app:backgroundTint="#002AFF"
                app:fabSize="mini" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fbThemLop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginLeft="160dp"
                android:layout_marginBottom="30dp"
                android:contentDescription="Sinh viên"
                android:src="@drawable/add64"
                app:backgroundTint="#6FFC01"
                app:fabSize="mini" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginLeft="160dp"
                android:layout_marginBottom="20dp"
                android:contentDescription="Mở menu"
                android:src="@drawable/ic_add"
                app:backgroundTint="#DA00FF"
                app:fabSize="normal" />
        </FrameLayout>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvAnHien"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Không có lớp trong danh sách"
        android:textColor="#3F51B5"
        android:visibility="invisible" />
</RelativeLayout>