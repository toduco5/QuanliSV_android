<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvMaMon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã môn: MH01"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvTenMon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên môn: Lập trình Java"
            android:layout_marginTop="4dp"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvSoTinChi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Số tín chỉ: 3"
            android:layout_marginTop="4dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTenNganhMon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngành: Công Nghệ Phần Mềm"
            android:layout_marginTop="4dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvHocKyMon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Học kỳ: 1"
            android:layout_marginTop="4dp"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNamHocMon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Năm học: 2025-2026"
            android:layout_marginTop="4dp"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>