<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#F5F7FB">

    <TextView
        android:id="@+id/tvTitleTaiKhoan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản Lý Tài Khoản"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#222222" />

    <TextView
        android:id="@+id/tvThongBaoTaiKhoan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tổng tài khoản: 0"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnThemTaiKhoan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THÊM TÀI KHOẢN"
        android:backgroundTint="#3F51B5"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp" />

    <ListView
        android:id="@+id/lvTaiKhoan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp" />

</LinearLayout>