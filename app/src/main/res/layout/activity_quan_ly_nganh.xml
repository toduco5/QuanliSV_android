<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F6FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quản lý ngành"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#222222"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/edtMaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mã ngành"
        android:minHeight="48dp" />

    <EditText
        android:id="@+id/edtTenNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên ngành"
        android:layout_marginTop="12dp"
        android:minHeight="48dp" />

    <Button
        android:id="@+id/btnThemNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="THÊM NGÀNH"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btnSuaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SỬA NGÀNH"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnXoaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XÓA NGÀNH"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnLamMoiNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LÀM MỚI"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnXemDanhSachNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XEM DANH SÁCH NGÀNH"
        android:layout_marginTop="10dp" />

</LinearLayout>