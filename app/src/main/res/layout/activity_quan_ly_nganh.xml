<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F7FB">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUẢN LÝ NGÀNH"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/edtMaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập mã ngành"
        android:inputType="text"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text" />

    <EditText
        android:id="@+id/edtTenNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập tên ngành"
        android:inputType="textCapWords"
        android:minHeight="48dp"
        android:padding="12dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnThemNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thêm ngành"
        android:minHeight="48dp"
        android:layout_marginTop="20dp" />

    <Button
        android:id="@+id/btnSuaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sửa ngành"
        android:minHeight="48dp"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnXoaNganh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xóa ngành"
        android:minHeight="48dp"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnLamMoi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Làm mới"
        android:minHeight="48dp"
        android:layout_marginTop="10dp" />

</LinearLayout>