<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvMaMonXem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mã môn: MH01"
        android:textStyle="bold"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvTenMonXem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Tên môn: Lập trình Java" />

    <TextView
        android:id="@+id/tvSoTinChiXem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Số tín chỉ: 3" />

    <TextView
        android:id="@+id/tvDiemXem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Điểm: 8.5" />
</LinearLayout>